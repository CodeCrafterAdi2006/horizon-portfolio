# === Backend Server Settings (Express) ===
# Acquire a Gemini API Key from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY="your_gemini_api_key_here"
SERVER_PORT=3001
NODE_ENV="development"

# === Frontend Integration Configuration ===
# Target local client port (for CORS configuration in server.js)
CLIENT_URL="http://localhost:3000"
