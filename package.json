{
  "name": "aditya-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite --port=3000 --host=0.0.0.0",
    "dev:backend": "node server.js",
    "dev": "concurrently --kill-others -n \"FRONTEND,BACKEND\" -c \"cyan,green\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "vite build",
    "server": "node server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.11.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.0",
    "lenis": "^1.3.23",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.2"
  }
}
